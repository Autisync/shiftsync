# ─────────────────────────────────────────────────────────
# ShiftSync – Production Environment
# All feature flags are OFF by default.
# Promote flags only after demo acceptance.
# ─────────────────────────────────────────────────────────

VITE_APP_ENV=production
VITE_BACKEND_MODE=supabase

VITE_SUPABASE_URL=https://your-prod-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-prod-anon-key

VITE_API_BASE_URL=

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

VITE_PUBLIC_APP_URL=https://yourdomain.com

# Keep all flags OFF until explicitly approved for production
VITE_ENABLE_SWAPS=false
VITE_ENABLE_LEAVE=false
VITE_ENABLE_SHARED_RECOVERY=false
VITE_ENABLE_REALTIME=false

# Required Supabase Edge Function secrets for HR emails (set server-side):
#   RESEND_API_KEY=...
#   EMAIL_FROM="ShiftSync <no-reply@yourdomain.com>"
# HR email policy: always CC the acting user + configured HR CC list.
