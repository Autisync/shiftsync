# ─────────────────────────────────────────────────────────
# ShiftSync – Demo / Staging Environment
# ─────────────────────────────────────────────────────────

VITE_APP_ENV=demo
VITE_BACKEND_MODE=supabase

VITE_SUPABASE_URL=https://your-demo-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-demo-anon-key

VITE_API_BASE_URL=

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

VITE_PUBLIC_APP_URL=https://demo.yourdomain.com

# New features are validated here before promoting to production
VITE_ENABLE_SWAPS=true
VITE_ENABLE_LEAVE=true
VITE_ENABLE_SHARED_RECOVERY=true
VITE_ENABLE_REALTIME=false

# Supabase Edge Function secrets (set in Supabase project secrets):
#   RESEND_API_KEY=...
#   EMAIL_FROM="ShiftSync <no-reply@yourdomain.com>"
# HR email policy: always CC the acting user + configured HR CC list.
