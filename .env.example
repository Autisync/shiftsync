# ───────────────────────────────────────
# ShiftSync – Environment Variables
# Copy this file to .env.local and fill in real values.
# ───────────────────────────────────────

# ── App environment ─────────────────────
# Options: local | demo | staging | production
VITE_APP_ENV=local

# ── Backend mode ────────────────────────
# Options: supabase | api
VITE_BACKEND_MODE=supabase

# ── Supabase (required when VITE_BACKEND_MODE=supabase) ─
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Custom HTTP API (required when VITE_BACKEND_MODE=api) ─
VITE_API_BASE_URL=

# ── Google OAuth / Calendar ─────────────
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

# ── Public app URL ──────────────────────
VITE_PUBLIC_APP_URL=http://localhost:5173

# ── Feature flags ───────────────────────
VITE_ENABLE_SWAPS=false
VITE_ENABLE_LEAVE=false
VITE_ENABLE_SHARED_RECOVERY=false
VITE_ENABLE_REALTIME=false

# ── Supabase Edge Function secrets (do NOT prefix with VITE_) ─
# Set these in Supabase, not in this frontend .env file:
#   supabase secrets set RESEND_API_KEY=... EMAIL_FROM="ShiftSync <no-reply@yourdomain.com>"
# Notes:
# - HR emails are sent via Resend.
# - The acting user is always CC'd automatically.
